{
  "name": "random-address-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Typed Fastify HTTP API for random Canadian address lookup over the local NAR Postgres database.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "RUN_DB_TESTS=1 vitest run"
  },
  "dependencies": {
    "@fastify/type-provider-typebox": "^5",
    "fastify": "^5",
    "pg": "^8"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/pg": "^8",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^2"
  }
}
