._*
.DS_Store
.env
.env.local
.env.*.local

# Node / TypeScript dependencies and build output.
node_modules/
/apps/*/node_modules/
/apps/*/dist/
/server/dist/
*.tsbuildinfo

# Playwright e2e artifacts.
/apps/*/test-results/
/apps/*/playwright-report/
/apps/*/blob-report/
/apps/*/playwright/.cache/

# Netlify CLI link state (site ID, etc.).
.netlify/

# Local Postgres storage and runtime files.
/.postgres/
/logs/

# Local Cloudflare tunnel config contains hostnames and credential paths.
/cloudflare/tunnel/config.yml

# Source and generated address data are large local artifacts.
/Addresses/
/ca/
/Random Address Generator/

# Temporary import scratch files.
/tmp/
*.log
