# Local API
# Dev mode defaults both API and web to local-dev-token when unset.
# Set this explicitly before exposing the API beyond localhost.
ADDRESS_API_TOKEN=local-dev-token
ADDRESS_API_HOST=127.0.0.1
ADDRESS_API_PORT=8787
ADDRESS_API_CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

# Web dev/build
VITE_ADDRESS_API_TOKEN=local-dev-token

# Postgres defaults mirror scripts/db-env.sh.
PGHOST=127.0.0.1
PGPORT=55432
PGDATABASE=random_address_retriever
PGUSER=janac

# Local API (server/) — optional overrides.
# ADDRESS_API_LOG=true
# PGPASSWORD=
# PG_POOL_MAX=10
# PG_STATEMENT_TIMEOUT_MS=30000

# Netlify server-side proxy values.
ADDRESS_API_URL=https://address-api.example.com
CF_ACCESS_CLIENT_ID=replace-with-cloudflare-access-client-id
CF_ACCESS_CLIENT_SECRET=replace-with-cloudflare-access-client-secret
