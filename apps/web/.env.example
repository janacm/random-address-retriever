# Environment variables for local development. Copy this to .env.local and fill in real values.
# Vite reads .env files from this app directory, not the repo root.

# API token — must match ADDRESS_API_TOKEN in the repo-root .env.local that the API loads
VITE_ADDRESS_API_TOKEN=

# PostHog analytics (https://app.posthog.com/project/<project_id>/settings/project)
VITE_POSTHOG_PROJECT_TOKEN=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://us.i.posthog.com
